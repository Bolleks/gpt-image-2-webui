# Auth secret for NextAuth (required, generate with: openssl rand -base64 32)
AUTH_SECRET=

# Webhook HMAC key (optional, for webhook verification)
WEBHOOK_HMAC_KEY=

# Base URL of this application (required, for webhook callback)
APP_URL=http://localhost:3000

# Image storage path (default: /data/images)
STORAGE_PATH=/data/images

# SQLite database URL (default: file:./data/app.db)
DATABASE_URL=file:./data/app.db